{
  "name": "transitmind",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "predev": "node scripts/ensure-env.mjs && kill-port 3001 5173 5174 5175 5176 || exit 0",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:backend": "npm --prefix backend run test",
    "test:backend:jest": "npm --prefix backend run test:jest",
    "migrate:core": "npm --prefix backend run migrate:core"
  },
  "devDependencies": {
    "kill-port": "^2.0.1",
    "concurrently": "^9.2.1"
  }
}
